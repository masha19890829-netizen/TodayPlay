{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://todayplay.example/contracts/provider-adapter-contract.schema.json",
  "title": "TodayPlay Travel Provider Adapter Contract",
  "type": "object",
  "required": [
    "adapter",
    "sourcePolicy",
    "contentSource",
    "itineraryPlan",
    "complianceNote"
  ],
  "properties": {
    "adapter": {
      "type": "object",
      "required": ["adapterName", "providerType", "contractVersion", "supportedLocales"],
      "properties": {
        "adapterName": { "type": "string", "minLength": 1 },
        "providerType": {
          "type": "string",
          "enum": [
            "official_map_api",
            "licensed_poi_dataset",
            "merchant_catalog",
            "operator_catalog",
            "user_authorized_link"
          ]
        },
        "contractVersion": { "type": "string", "minLength": 1 },
        "supportedLocales": {
          "type": "array",
          "items": { "$ref": "#/$defs/locale" },
          "minItems": 1
        }
      },
      "additionalProperties": false
    },
    "sourcePolicy": { "$ref": "#/$defs/sourcePolicy" },
    "contentSource": { "$ref": "#/$defs/contentSource" },
    "itineraryPlan": { "$ref": "#/$defs/itineraryPlan" },
    "complianceNote": { "$ref": "#/$defs/complianceNote" }
  },
  "additionalProperties": false,
  "$defs": {
    "locale": {
      "type": "string",
      "enum": ["zh-CN", "zh-TW", "en", "ja", "ko", "es"]
    },
    "sourcePolicy": {
      "type": "object",
      "required": [
        "noScraping",
        "allowedUses",
        "forbiddenUses",
        "retentionPolicy",
        "attributionRequired",
        "reviewRequired",
        "policyNotes"
      ],
      "properties": {
        "noScraping": { "const": true },
        "allowedUses": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "forbiddenUses": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "retentionPolicy": { "type": "string", "minLength": 1 },
        "attributionRequired": { "type": "boolean" },
        "attributionText": { "type": ["string", "null"] },
        "reviewRequired": { "type": "boolean" },
        "policyNotes": { "type": "array", "items": { "type": "string" }, "minItems": 1 }
      },
      "additionalProperties": false
    },
    "contentSource": {
      "type": "object",
      "required": [
        "sourceId",
        "sourceLabel",
        "sourceType",
        "licenseName",
        "licenseScope",
        "retrievedAt",
        "requiresOfficialVerification",
        "mock"
      ],
      "properties": {
        "sourceId": { "type": "string", "minLength": 1 },
        "sourceLabel": { "type": "string", "minLength": 1 },
        "sourceType": {
          "type": "string",
          "enum": [
            "official_map_api",
            "licensed_poi_dataset",
            "merchant_catalog",
            "operator_catalog",
            "user_authorized_link"
          ]
        },
        "sourceUrl": { "type": ["string", "null"] },
        "licenseName": { "type": "string", "minLength": 1 },
        "licenseScope": { "type": "string", "minLength": 1 },
        "retrievedAt": { "type": "string", "format": "date-time" },
        "expiresAt": { "type": ["string", "null"], "format": "date-time" },
        "requiresOfficialVerification": { "type": "boolean" },
        "mock": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "imageAsset": {
      "type": "object",
      "required": [
        "assetId",
        "kind",
        "url",
        "altText",
        "width",
        "height",
        "licenseName",
        "licenseHolder",
        "licenseScope",
        "requiresAttribution"
      ],
      "properties": {
        "assetId": { "type": "string", "minLength": 1 },
        "kind": {
          "type": "string",
          "enum": ["thumbnail", "hero", "map_preview", "operator_placeholder"]
        },
        "url": { "type": "string", "minLength": 1 },
        "altText": { "type": "string", "minLength": 1 },
        "width": { "type": "integer", "minimum": 1 },
        "height": { "type": "integer", "minimum": 1 },
        "licenseName": { "type": "string", "minLength": 1 },
        "licenseHolder": { "type": "string", "minLength": 1 },
        "licenseScope": { "type": "string", "minLength": 1 },
        "expiresAt": { "type": ["string", "null"], "format": "date-time" },
        "requiresAttribution": { "type": "boolean" },
        "attributionText": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "poi": {
      "type": "object",
      "required": [
        "poiId",
        "name",
        "country",
        "city",
        "district",
        "address",
        "latitude",
        "longitude",
        "tags",
        "suitableFor",
        "budgetLevel",
        "estimatedStayMinutes",
        "bestVisitTime",
        "recommendationReason",
        "riskTips",
        "imageAssets",
        "contentSource",
        "sourcePolicy",
        "freshness"
      ],
      "properties": {
        "poiId": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "country": { "type": "string", "minLength": 1 },
        "city": { "type": "string", "minLength": 1 },
        "district": { "type": "string" },
        "address": { "type": "string", "minLength": 1 },
        "latitude": { "type": "number", "minimum": -90, "maximum": 90 },
        "longitude": { "type": "number", "minimum": -180, "maximum": 180 },
        "tags": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "suitableFor": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "budgetLevel": { "type": "string", "minLength": 1 },
        "estimatedStayMinutes": { "type": "integer", "minimum": 1 },
        "bestVisitTime": { "type": "string", "minLength": 1 },
        "recommendationReason": { "type": "string", "minLength": 1 },
        "riskTips": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "imageAssets": { "type": "array", "items": { "$ref": "#/$defs/imageAsset" } },
        "contentSource": { "$ref": "#/$defs/contentSource" },
        "sourcePolicy": { "$ref": "#/$defs/sourcePolicy" },
        "freshness": {
          "type": "object",
          "required": ["retrievedAt", "staleAfter"],
          "properties": {
            "retrievedAt": { "type": "string", "format": "date-time" },
            "staleAfter": { "type": "string", "format": "date-time" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "checkInTask": {
      "type": "object",
      "required": ["taskId", "title", "rewardPoints"],
      "properties": {
        "taskId": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "rewardPoints": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "navigationAction": {
      "type": "object",
      "required": ["destinationName", "latitude", "longitude", "address"],
      "properties": {
        "destinationName": { "type": "string", "minLength": 1 },
        "latitude": { "type": "number", "minimum": -90, "maximum": 90 },
        "longitude": { "type": "number", "minimum": -180, "maximum": 180 },
        "address": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "routeStop": {
      "type": "object",
      "required": [
        "order",
        "poi",
        "startTimeHint",
        "stayMinutes",
        "checkInTask",
        "photoSuggestion",
        "spendingSuggestion",
        "backupPlan",
        "navigationAction",
        "whyForGroup",
        "riskTips",
        "contentSource",
        "sourcePolicy"
      ],
      "properties": {
        "order": { "type": "integer", "minimum": 1 },
        "poi": { "$ref": "#/$defs/poi" },
        "startTimeHint": { "type": "string", "minLength": 1 },
        "stayMinutes": { "type": "integer", "minimum": 1 },
        "checkInTask": { "$ref": "#/$defs/checkInTask" },
        "photoSuggestion": { "type": "string", "minLength": 1 },
        "spendingSuggestion": { "type": "string", "minLength": 1 },
        "backupPlan": { "type": "string", "minLength": 1 },
        "navigationAction": { "$ref": "#/$defs/navigationAction" },
        "whyForGroup": { "type": "string", "minLength": 1 },
        "riskTips": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "contentSource": { "$ref": "#/$defs/contentSource" },
        "sourcePolicy": { "$ref": "#/$defs/sourcePolicy" }
      },
      "additionalProperties": false
    },
    "itineraryPlan": {
      "type": "object",
      "required": [
        "planId",
        "planType",
        "locale",
        "title",
        "city",
        "routeSummary",
        "estimatedCost",
        "bestPhotoTime",
        "crowdRisk",
        "candidateRouteCount",
        "stops",
        "rewardPolicy",
        "complianceNote",
        "marketCoverageNote",
        "contentSource",
        "sourcePolicy"
      ],
      "properties": {
        "planId": { "type": "string", "minLength": 1 },
        "planType": { "type": "string", "minLength": 1 },
        "locale": { "$ref": "#/$defs/locale" },
        "title": { "type": "string", "minLength": 1 },
        "city": { "type": "string", "minLength": 1 },
        "routeSummary": { "type": "string", "minLength": 1 },
        "estimatedCost": { "type": "string", "minLength": 1 },
        "bestPhotoTime": { "type": "string", "minLength": 1 },
        "crowdRisk": { "type": "string", "minLength": 1 },
        "candidateRouteCount": { "type": "integer", "minimum": 1 },
        "stops": { "type": "array", "items": { "$ref": "#/$defs/routeStop" }, "minItems": 1 },
        "rewardPolicy": { "type": "string", "minLength": 1 },
        "complianceNote": { "$ref": "#/$defs/complianceNote" },
        "marketCoverageNote": { "type": "string", "minLength": 1 },
        "contentSource": { "$ref": "#/$defs/contentSource" },
        "sourcePolicy": { "$ref": "#/$defs/sourcePolicy" }
      },
      "additionalProperties": false
    },
    "complianceNote": {
      "type": "object",
      "required": [
        "summary",
        "mockData",
        "requiresBackend",
        "requiresOfficialApiOrLicense",
        "requiresImageLicense",
        "requiresPrivacyReview",
        "unsupportedClaims"
      ],
      "properties": {
        "summary": { "type": "string", "minLength": 1 },
        "mockData": { "type": "boolean" },
        "requiresBackend": { "type": "boolean" },
        "requiresOfficialApiOrLicense": { "type": "boolean" },
        "requiresImageLicense": { "type": "boolean" },
        "requiresPrivacyReview": { "type": "boolean" },
        "unsupportedClaims": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        }
      },
      "additionalProperties": false
    }
  }
}
